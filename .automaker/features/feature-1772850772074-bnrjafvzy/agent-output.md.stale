  "old_string": "    // Restart auto-mode with the same configuration\n    try {\n      await this.startAutoLoopForProject(\n        projectPath,\n        projectState.branchName ?? null,\n        projectState.config.maxConcurrency\n      );\n    } catch (error) {\n      logger.error('Failed to auto-resume after cooldown:', error);\n      this.emitAutoModeEvent('auto_mode_error', {\n        message: 'Failed to auto-resume after cooldown',\n        error: error instanceof Error ? error.message : String(error),\n        projectPath,\n      });\n    }",
  "new_string": "    // Guard against race: the previous loop may still be cleaning up when the\n    // cooldown timer fires. If the loop is already running (or a start is\n    // pending), skip silently â€” the loop is healthy and doesn't need a nudge.\n    if (this.coordinator.isRunning(worktreeKey) || this.pendingLoopStarts.has(worktreeKey)) {\n      logger.debug(\n        `Auto-mode already running for ${projectPath} when cooldown timer fired; skipping resume`\n      );\n      return;\n    }\n\n    // Restart auto-mode with the same configuration\n    try {\n      await this.startAutoLoopForProject(\n        projectPath,\n        projectState.branchName ?? null,\n        projectState.config.maxConcurrency\n      );\n    } catch (error) {\n      logger.error('Failed to auto-resume after cooldown:', error);\n      this.emitAutoModeEvent('auto_mode_error', {\n        message: 'Failed to auto-resume after cooldown',\n        error: error instanceof Error ? error.message : String(error),\n        projectPath,\n      });\n    }"
}
