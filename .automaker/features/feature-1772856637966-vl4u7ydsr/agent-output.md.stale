Input: {
  "file_path": "/Users/kj/dev/automaker/.github/workflows/promotion-check-staging.yml",
  "content": "# SECURITY: This workflow is hardened against fork PR attacks. See docs/security/ci-hardening.md\nname: Promotion Check (Staging)\n\n# Enforces the branch strategy: only `dev` or `promote/*` may open PRs into `staging`.\n# All other source branches are rejected with a clear error message.\non:\n  pull_request:\n    branches:\n      - staging\n\npermissions: read-all\n\njobs:\n  source-branch:\n    runs-on: self-hosted\n    if: github.event.pull_request.head.repo.full_name == github.repository\n    steps:\n      - name: Verify PR source is dev or promote/*\n        run: |\n          SOURCE=\"${{ github.head_ref }}\"\n          echo \"PR source branch: $SOURCE\"\n          if [ \"$SOURCE\" = \"dev\" ]; then\n            echo \"✅ Source branch is 'dev' — promotion to staging approved\"\n            exit 0\n          fi\n          if [[ \"$SOURCE\" == promote/* ]]; then\n            echo \"✅ Source branch matches 'promote/*' — promotion to staging approved\"\n            exit 0\n          fi\n          echo \"::error::PRs to staging must come from the 'dev' branch or a 'promote/*' branch.\"\n          echo \"::error::Current source: '$SOURCE'\"\n          echo \"\"\n          echo \"Branch strategy:\"\n          echo \"  dev  →  staging  →  main\"\n          echo \"\"\n          echo \"To promote to staging:\"\n          echo \"  1. Merge your work into dev first\"\n          echo \"  2. Open a PR from dev → staging (or from a promote/* branch)\"\n          echo \"  3. CI runs the full suite; merge triggers auto-deploy to the staging environment\"\n          exit 1\n"
}

