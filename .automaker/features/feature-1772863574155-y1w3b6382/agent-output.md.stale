Input: {
  "file_path": "/Users/kj/dev/automaker/apps/server/src/services/project-artifact-service.ts",
  "content": "/**\n * ProjectArtifactService — Persists project artifacts to disk.\n *\n * Artifacts are written to:\n *   .automaker/projects/{slug}/artifacts/{type}/{id}.json\n *\n * An index file is maintained at:\n *   .automaker/projects/{slug}/artifacts/index.json\n *\n * Supported types: 'ceremony-report' | 'changelog' | 'escalation' | 'standup'\n */\n\nimport fs from 'fs';\nimport path from 'path';\nimport { createLogger } from '@protolabsai/utils';\nimport { getProjectDir } from '@protolabsai/platform';\nimport type { ArtifactType, ArtifactIndex, ArtifactIndexEntry, ProjectArtifact } from '@protolabsai/types';\n\nconst logger = createLogger('ProjectArtifactService');\n\nexport class ProjectArtifactService {\n  // ---------------------------------------------------------------------------\n  // Public API\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Save an artifact to disk and update the index.\n   * Returns the generated artifact ID.\n   */\n  async saveArtifact(\n    projectPath: string,\n    slug: string,\n    type: ArtifactType,\n    content: unknown\n  ): Promise<string> {\n    const id = this.generateId();\n    const timestamp = new Date().toISOString();\n    const filename = `${id}.json`;\n\n    const artifactsBase = this.getArtifactsBase(projectPath, slug);\n    const typeDir = path.join(artifactsBase, type);\n\n    // Ensure directories exist\n    await fs.promises.mkdir(typeDir, { recursive: true });\n\n    // Write artifact file\n    const artifact: ProjectArtifact = { id, type, timestamp, content };\n    const artifactPath = path.join(typeDir, filename);\n    await fs.promises.writeFile(artifactPath, JSON.stringify(artifact, null, 2), 'utf-8');\n\n    // Update index\n    await this.appendToIndex(artifactsBase, { id, type, timestamp, filename });\n\n    logger.debug(`Saved artifact ${id} (${type}) for project ${slug}`);\n    return id;\n  }\n\n  /**\n   * List artifact index entries for a project, optionally filtered by type.\n   */\n  async listArtifacts(\n    projectPath: string,\n    slug: string,\n    type?: ArtifactType\n  ): Promise<ArtifactIndexEntry[]> {\n    const artifactsBase = this.getArtifactsBase(projectPath, slug);\n    const index = await this.readIndex(artifactsBase);\n\n    if (type) {\n      return index.entries.filter((e) => e.type === type);\n    }\n    return index.entries;\n  }\n\n  /**\n   * Get the full content of an artifact by ID.\n   * Throws if the artifact ID is not found in the index.\n   */\n  async getArtifact(projectPath: string, slug: string, artifactId: string): Promise<unknown> {\n    const artifactsBase = this.getArtifactsBase(projectPath, slug);\n    const index = await this.readIndex(artifactsBase);\n\n    const entry = index.entries.find((e) => e.id === artifactId);\n    if (!entry) {\n      throw new Error(`Artifact not found: ${artifactId}`);\n    }\n\n    const artifactPath = path.join(artifactsBase, entry.type, entry.filename);\n    const raw = await fs.promises.readFile(artifactPath, 'utf-8');\n    const artifact = JSON.parse(raw) as ProjectArtifact;\n    return artifact.content;\n  }\n\n  // ---------------------------------------------------------------------------\n  // Private helpers\n  // ---------------------------------------------------------------------------\n\n  private getArtifactsBase(projectPath: string, slug: string): string {\n    return path.join(getProjectDir(projectPath, slug), 'artifacts');\n  }\n\n  private getIndexPath(artifactsBase: string): string {\n    return path.join(artifactsBase, 'index.json');\n  }\n\n  private async readIndex(artifactsBase: string): Promise<ArtifactIndex> {\n    const indexPath = this.getIndexPath(artifactsBase);\n    try {\n      const raw = await fs.promises.readFile(indexPath, 'utf-8');\n      return JSON.parse(raw) as ArtifactIndex;\n    } catch {\n      return { version: 1, entries: [] };\n    }\n  }\n\n  private async appendToIndex(artifactsBase: string, entry: ArtifactIndexEntry): Promise<void> {\n    await fs.promises.mkdir(artifactsBase, { recursive: true });\n    const index = await this.readIndex(artifactsBase);\n    index.entries.push(entry);\n    const indexPath = this.getIndexPath(artifactsBase);\n    await fs.promises.writeFile(indexPath, JSON.stringify(index, null, 2), 'utf-8');\n  }\n\n  private generateId(): string {\n    // Use crypto.randomUUID if available (Node 15+), otherwise fallback\n    if (typeof crypto !== 'undefined' && crypto.randomUUID) {\n      return crypto.randomUUID();\n    }\n    return `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;\n  }\n}\n\n// Singleton instance\nexport const projectArtifactService = new ProjectArtifactService();\n"
}

