  "file_path": "/Users/kj/dev/automaker/apps/server/tests/unit/services/ceremony-flows.test.ts",
  "content": "/**\n * Ceremony Flow Registry Tests\n *\n * Verifies that CeremonyService.initialize() registers all 3 ceremony flows\n * in the FlowRegistry before any ceremony triggers can be dispatched.\n *\n * Regression guard for: \"Flow not registered: standup-flow\" errors.\n */\n\nimport { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { CeremonyService } from '../../../src/services/ceremony-service.js';\nimport { flowRegistry } from '../../../src/services/automation-service.js';\nimport { createEventEmitter } from '../../../src/lib/events.js';\nimport type { SettingsService } from '../../../src/services/settings-service.js';\nimport type { FeatureLoader } from '../../../src/services/feature-loader.js';\nimport type { ProjectService } from '../../../src/services/project-service.js';\nimport type { MetricsService } from '../../../src/services/metrics-service.js';\n\n// ---------------------------------------------------------------------------\n// Module mocks — prevent real LLM calls / FS access\n// ---------------------------------------------------------------------------\n\nvi.mock('@langchain/anthropic', () => ({\n  ChatAnthropic: vi.fn().mockImplementation(() => ({})),\n}));\n\nvi.mock('@protolabsai/flows', () => ({\n  createStandupFlow: vi.fn(),\n  createRetroFlow: vi.fn(),\n  createProjectRetroFlow: vi.fn(),\n}));\n\nvi.mock('@protolabsai/platform', async (importOriginal) => {\n  const original = await importOriginal<typeof import('@protolabsai/platform')>();\n  return {\n    ...original,\n    getDataDirectory: vi.fn().mockReturnValue(null),\n    getProjectDir: vi.fn().mockReturnValue('/tmp/test-project'),\n    secureFs: {\n      readFile: vi.fn().mockRejectedValue(new Error('no file')),\n      writeFile: vi.fn().mockResolvedValue(undefined),\n      mkdir: vi.fn().mockResolvedValue(undefined),\n    },\n  };\n});\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nconst createMockSettingsService = (): SettingsService =>\n  ({ getProjectSettings: vi.fn() }) as unknown as SettingsService;\n\nconst createMockFeatureLoader = (): FeatureLoader =>\n  ({ getAll: vi.fn() }) as unknown as FeatureLoader;\n\nconst createMockProjectService = (): ProjectService =>\n  ({ getProject: vi.fn() }) as unknown as ProjectService;\n\nconst createMockMetricsService = (): MetricsService => ({}) as unknown as MetricsService;\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\ndescribe('CeremonyService — flow registry', () => {\n  let service: CeremonyService;\n\n  beforeEach(() => {\n    service = new CeremonyService();\n    const emitter = createEventEmitter();\n    service.initialize(\n      emitter,\n      createMockSettingsService(),\n      createMockFeatureLoader(),\n      createMockProjectService(),\n      createMockMetricsService()\n    );\n  });\n\n  it('registers standup-flow in the FlowRegistry on init', () => {\n    expect(flowRegistry.has('standup-flow')).toBe(true);\n  });\n\n  it('registers retro-flow in the FlowRegistry on init', () => {\n    expect(flowRegistry.has('retro-flow')).toBe(true);\n  });\n\n  it('registers project-retro-flow in the FlowRegistry on init', () => {\n    expect(flowRegistry.has('project-retro-flow')).toBe(true);\n  });\n\n  it('registers all 3 ceremony flows before any ceremony triggers', () => {\n    const expectedFlows = ['standup-flow', 'retro-flow', 'project-retro-flow'];\n    for (const flowId of expectedFlows) {\n      expect(flowRegistry.has(flowId), `Expected ${flowId} to be registered`).toBe(true);\n    }\n  });\n\n  it('standup-flow factory is callable without throwing', async () => {\n    const factory = flowRegistry.get('standup-flow');\n    expect(factory).toBeDefined();\n    await expect(factory!({})).resolves.toBeUndefined();\n  });\n\n  it('retro-flow factory is callable without throwing', async () => {\n    const factory = flowRegistry.get('retro-flow');\n    expect(factory).toBeDefined();\n    await expect(factory!({})).resolves.toBeUndefined();\n  });\n\n  it('project-retro-flow factory is callable without throwing', async () => {\n    const factory = flowRegistry.get('project-retro-flow');\n    expect(factory).toBeDefined();\n    await expect(factory!({})).resolves.toBeUndefined();\n  });\n});\n"
}
