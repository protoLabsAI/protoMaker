  "content": "/**\n * Temporary verification script for spec.md generation feature.\n * Run with: npx tsx apps/server/src/services/__verify-spec-md.mts\n */\nimport { generateSpecMd } from './repo-research-service.js';\nimport type { RepoResearchResult } from '@protolabsai/types';\n\n// Minimal stub for a monorepo project\nconst fakeResearch: RepoResearchResult = {\n  projectPath: '/tmp/test-project',\n  projectName: 'test-project',\n  scripts: { build: 'tsc', test: 'vitest', dev: 'vite' },\n  git: { isRepo: true, remoteUrl: 'https://github.com/org/test-project', defaultBranch: 'main', provider: 'github' },\n  monorepo: {\n    isMonorepo: true,\n    tool: 'turbo',\n    packageManager: 'pnpm',\n    workspaceGlobs: ['apps/*', 'packages/*'],\n    packages: [\n      { name: '@test/app', path: 'apps/web', type: 'app' },\n      { name: '@test/ui', path: 'packages/ui', type: 'package' },\n    ],\n  },\n  frontend: { framework: 'react', reactVersion: '18.3.0', metaFramework: 'vite', metaFrameworkVersion: '5.0.0', hasShadcn: true, hasStorybook: false, hasTailwind: true, tailwindVersion: '3.4.0', hasRadix: false },\n  backend: { hasPayload: false, database: 'postgres', hasExpress: true, hasFastAPI: false },\n  agents: { hasMCPServers: false, mcpPackages: [], hasLangGraph: false, hasClaudeSDK: true, hasAgentFolder: false },\n  testing: { hasVitest: true, vitestVersion: '1.6.0', hasPlaywright: true, playwrightVersion: '1.44.0', hasJest: false, hasPytest: false, testDirs: ['tests', 'e2e'] },\n  codeQuality: { hasESLint: true, eslintVersion: '9.0.0', hasPrettier: true, hasTypeScript: true, tsVersion: '5.4.0', tsStrict: true, hasCompositeConfig: false, hasHusky: true, hasLintStaged: true },\n  ci: { hasCI: true, provider: 'github-actions', workflows: ['ci.yml'], hasBuildCheck: true, hasTestCheck: true, hasFormatCheck: true, hasSecurityAudit: true, hasCodeRabbit: false, hasBranchProtection: true },\n  automation: { hasAutomaker: false, hasDiscordIntegration: false, hasProtolabConfig: false, hasAnalytics: false },\n  python: { hasPythonServices: false, services: [], hasRuff: false, hasBlack: false, hasPytest: false, hasPoetry: false, hasPyproject: false },\n  structure: { topDirs: ['apps', 'packages', 'docs', '.github'], configFiles: ['turbo.json', 'package.json'], entryPoints: [] },\n};\n\nconsole.log('=== Verifying generateSpecMd ===\\n');\n\n// Test 1: Basic generation with description\nconst specContent = generateSpecMd('test-project', fakeResearch, 'A test project description');\n\n// Check: Header present\nconsole.assert(specContent.includes('# test-project'), 'FAIL: Header missing');\nconsole.log('✓ Header present');\n\n// Check: Description present\nconsole.assert(specContent.includes('A test project description'), 'FAIL: Description missing');\nconsole.log('✓ Description present');\n\n// Check: Tech stack detected\nconsole.assert(specContent.includes('TypeScript'), 'FAIL: TypeScript not detected');\nconsole.assert(specContent.includes('react'), 'FAIL: React not detected');\nconsole.assert(specContent.includes('Tailwind CSS'), 'FAIL: Tailwind not detected');\nconsole.assert(specContent.includes('Anthropic Claude SDK'), 'FAIL: Claude SDK not detected');\nconsole.log('✓ Tech stack auto-detected');\n\n// Check: Architecture section reflects monorepo\nconsole.assert(specContent.includes('Monorepo'), 'FAIL: Architecture section missing monorepo info');\nconsole.assert(specContent.includes('apps/web'), 'FAIL: Package paths missing in architecture');\nconsole.assert(specContent.includes('packages/ui'), 'FAIL: Package paths missing in architecture');\nconsole.log('✓ Architecture section reflects actual repo structure');\n\n// Check: Placeholder sections present\nconsole.assert(specContent.includes('## Product Goals'), 'FAIL: Product Goals section missing');\nconsole.assert(specContent.includes('## Target Users'), 'FAIL: Target Users section missing');\nconsole.assert(specContent.includes('## Key Workflows'), 'FAIL: Key Workflows section missing');\nconsole.assert(specContent.includes('## Constraints & Non-Goals'), 'FAIL: Constraints section missing');\nconsole.assert(specContent.includes('<!-- TODO:'), 'FAIL: TODO placeholders missing');\nconsole.log('✓ Placeholder sections clearly marked with TODO comments');\n\n// Check: Key dependencies\nconsole.assert(specContent.includes('## Key Dependencies'), 'FAIL: Key Dependencies section missing');\nconsole.assert(specContent.includes('`typescript`'), 'FAIL: typescript missing from dependencies');\nconsole.log('✓ Key dependencies auto-detected');\n\n// Test 2: Without description (uses placeholder)\nconst specNoDesc = generateSpecMd('no-desc-project', fakeResearch);\nconsole.assert(specNoDesc.includes('_[Detected from package.json/README'), 'FAIL: Placeholder description missing when no description provided');\nconsole.log('✓ Placeholder description shown when no description provided');\n\n// Test 3: Non-monorepo (single package repo)\nconst singlePkgResearch: RepoResearchResult = {\n  ...fakeResearch,\n  monorepo: { isMonorepo: false, packageManager: 'npm', packages: [], workspaceGlobs: undefined },\n  structure: { topDirs: ['src', 'tests', 'docs'], configFiles: ['package.json'], entryPoints: ['index.ts'] },\n};\nconst specSingle = generateSpecMd('single-pkg', singlePkgResearch);\nconsole.assert(specSingle.includes('Single-package repository'), 'FAIL: Single-package type missing');\nconsole.assert(specSingle.includes('`src/`'), 'FAIL: Top-level dirs missing for single-package repo');\nconsole.log('✓ Single-package repo architecture section shows top-level directories');\n\nconsole.log('\\n=== All checks passed ===');\n"
