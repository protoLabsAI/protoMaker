Input: {
  "replace_all": false,
  "file_path": "/home/josh/dev/ava/.worktrees/feature-projects-and-project-sync/libs/crdt/src/crdt-store.ts",
  "old_string": "  /**\n   * Get or create an Automerge document for the given key.\n   * If no document exists, initializes one using the provided factory.\n   */\n  getOrCreate<T extends Record<string, unknown>>(key: string, init: () => T): Automerge.Doc<T> {\n    const entry = this.docs.get(key);\n    if (entry) {\n      return entry.doc as Automerge.Doc<T>;\n    }\n    const doc = Automerge.from<T>(init());\n    this.docs.set(key, { doc, callbacks: new Set() });\n    return doc;\n  }",
  "new_string": "  /**\n   * Get or create an Automerge document for the given key.\n   * If no document exists, initializes one using the provided factory.\n   */\n  getOrCreate<T>(key: string, init: () => T): Automerge.Doc<T> {\n    const entry = this.docs.get(key);\n    if (entry) {\n      return entry.doc as Automerge.Doc<T>;\n    }\n    // Automerge.from requires T extends Record<string, unknown> but we cast via unknown\n    const doc = Automerge.from<T>(init() as T & Record<string, unknown>) as Automerge.Doc<T>;\n    this.docs.set(key, { doc, callbacks: new Set() });\n    return doc;\n  }"
}

