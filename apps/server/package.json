{
  "name": "@protolabsai/server",
  "version": "0.50.0",
  "description": "Backend server for protoLabs Studio - provides API for both web and Electron modes",
  "author": "protoLabs Studio",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=16384' tsx watch --ignore '**/.automaker/**' --ignore '**/.automaker-lock' --ignore '**/.worktrees/**' --ignore '**/dist/**' --ignore '../../libs/**/dist/**' --ignore '../../packages/**/dist/**' --ignore 'data/**' --ignore '**/*.log' src/index.ts",
    "dev:test": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"import{cpSync,mkdirSync}from'fs';import{dirname,join}from'path';import{execSync}from'child_process';const files=execSync('find src -name *.md',{encoding:'utf8'}).trim().split('\\n').filter(Boolean);for(const f of files){const d=f.replace(/^src/,'dist');mkdirSync(dirname(d),{recursive:true});cpSync(f,d)}\" --input-type=module",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:headless": "NODE_ENV=production AUTO_MODE=true node dist/index.js",
    "lint": "eslint src/ tests/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.45",
    "@ai-sdk/react": "^3.0.92",
    "@anthropic-ai/claude-agent-sdk": "^0.2.36",
    "@automerge/automerge": "^3.2.4",
    "@anthropic-ai/sdk": "^0.65.0",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.80",
    "@langchain/groq": "^0.1.3",
    "@langchain/openai": "^0.3.17",
    "@langfuse/otel": "^4.6.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@napi-rs/whisper": "^0.0.4",
    "@octokit/rest": "^22.0.1",
    "@openai/codex-sdk": "^0.98.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.212.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@protolabsai/crdt": "^0.42.8",
    "@protolabsai/dependency-resolver": "^0.50.0",
    "@protolabsai/error-tracking": "^0.42.8",
    "@protolabsai/flows": "^0.50.0",
    "@protolabsai/git-utils": "^0.50.0",
    "@protolabsai/model-resolver": "^0.50.0",
    "@protolabsai/observability": "^0.50.0",
    "@protolabsai/platform": "^0.50.0",
    "@protolabsai/prompts": "^0.50.0",
    "@protolabsai/tools": "^0.50.0",
    "@protolabsai/types": "^0.50.0",
    "@protolabsai/utils": "^0.50.0",
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "@twurple/chat": "^8.0.3",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.90",
    "better-sqlite3": "^11.7.0",
    "cookie": "0.7.2",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "^8.2.1",
    "groq-sdk": "^0.5.0",
    "morgan": "1.10.1",
    "node-pty": "1.1.0-beta41",
    "openai": "^4.104.0",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "ws": "8.18.3",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie": "0.6.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "22.19.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/ui": "4.0.16",
    "eslint": "^10.0.0",
    "eslint-plugin-n": "^17.23.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
