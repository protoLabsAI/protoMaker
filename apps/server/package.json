{
  "name": "@automaker/server",
  "version": "0.2.0",
  "description": "Backend server for Automaker - provides API for both web and Electron modes",
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=16384' tsx watch --ignore '**/.automaker/**' --ignore '**/.worktrees/**' --ignore '**/dist/**' --ignore '../../libs/**/dist/**' --ignore '../../packages/**/dist/**' --ignore 'data/**' --ignore '**/*.log' src/index.ts",
    "dev:test": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.45",
    "@ai-sdk/react": "^3.0.92",
    "@anthropic-ai/claude-agent-sdk": "^0.2.36",
    "@anthropic-ai/sdk": "^0.65.0",
    "@automaker/dependency-resolver": "0.2.0",
    "@automaker/flows": "0.2.0",
    "@automaker/git-utils": "0.2.0",
    "@automaker/llm-providers": "0.2.0",
    "@automaker/model-resolver": "0.2.0",
    "@automaker/observability": "0.2.0",
    "@automaker/platform": "0.2.0",
    "@automaker/prompts": "0.2.0",
    "@automaker/types": "0.2.0",
    "@automaker/utils": "0.2.0",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.80",
    "@langfuse/otel": "^4.6.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@napi-rs/whisper": "^0.0.4",
    "@octokit/rest": "^22.0.1",
    "@openai/codex-sdk": "^0.98.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "@twurple/chat": "^8.0.3",
    "ai": "^6.0.90",
    "cookie": "0.7.2",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "^8.2.1",
    "morgan": "1.10.1",
    "node-pty": "1.1.0-beta41",
    "uuid": "^13.0.0",
    "ws": "8.18.3",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@types/cookie": "0.6.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "22.19.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/ui": "4.0.16",
    "eslint": "^10.0.0",
    "eslint-plugin-n": "^17.23.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
