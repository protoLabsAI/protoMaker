{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@protolabsai/crdt": ["../../libs/crdt/dist/index.d.ts"],
      "@protolabsai/dependency-resolver": ["../../libs/dependency-resolver/dist/index.d.ts"],
      "@protolabsai/error-tracking": ["../../libs/error-tracking/dist/index.d.ts"],
      "@protolabsai/flows": ["../../libs/flows/dist/index.d.ts"],
      "@protolabsai/git-utils": ["../../libs/git-utils/dist/index.d.ts"],
      "@protolabsai/model-resolver": ["../../libs/model-resolver/dist/index.d.ts"],
      "@protolabsai/observability": ["../../libs/observability/dist/index.d.ts"],
      "@protolabsai/platform": ["../../libs/platform/dist/index.d.ts"],
      "@protolabsai/prompts": ["../../libs/prompts/dist/index.d.ts"],
      "@protolabsai/tools": ["../../libs/tools/dist/index.d.ts"],
      "@protolabsai/types": ["../../libs/types/dist/index.d.ts"],
      "@protolabsai/utils": ["../../libs/utils/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
