    "cross-env": "10.1.0",
    "electron": "39.2.7",
    "electron-builder": "^26.7.0",
    "eslint": "9.39.2",
    "eslint-plugin-storybook": "^10.2.8",
    "sharp": "^0.34.5",
    "storybook": "^10.2.8",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vite-plugin-electron": "0.29.0",
    "vite-plugin-electron-renderer": "0.14.6",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "studio.protolabs.app",
    "productName": "protoLabs.studio",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "protoLabsAI",
      "repo": "automaker"
    },
    "afterPack": "./scripts/rebuild-server-natives.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server-bundle/dist",
        "to": "server"
      },
      {
        "from": "server-bundle/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "server-bundle/package.json",
        "to": "server/package.json"
      },
      {
        "from": "../../.env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "protoLabs Studio needs microphone access for voice activation and wake word detection."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "public/logo_larger.png",
      "maintainer": "hello@protolabs.studio",
      "executableName": "automaker",
      "description": "An autonomous AI development studio that helps you build software faster using AI-powered agents",
      "synopsis": "AI-powered autonomous development studio"
    },
    "rpm": {
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-core",
        "libuuid"
      ],
      "compression": "xz",
      "vendor": "AutoMaker Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
