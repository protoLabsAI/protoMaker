{
  "name": "@protolabsai/crdt",
  "version": "0.42.8",
  "type": "module",
  "description": "CRDT document store wrapping Automerge + automerge-repo for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:check": "tsc --noEmit"
  },
  "keywords": [
    "automaker",
    "crdt",
    "automerge",
    "collaboration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@protolabsai/types": "^0.50.0",
    "@automerge/automerge": "^3.2.4",
    "@automerge/automerge-repo": "^2.5.3",
    "@automerge/automerge-repo-network-websocket": "^2.5.3",
    "@automerge/automerge-repo-storage-nodefs": "^2.5.3"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "@types/ws": "^8.5.10",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16",
    "ws": "^8.18.0"
  }
}
