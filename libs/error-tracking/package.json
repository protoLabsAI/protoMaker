{
  "name": "@protolabsai/error-tracking",
  "version": "0.42.2",
  "type": "module",
  "description": "Error tracking and monitoring with Sentry integration for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:check": "tsc --noEmit"
  },
  "keywords": [
    "automaker",
    "error-tracking",
    "sentry",
    "monitoring"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@protolabsai/types": "^0.44.0",
    "@protolabsai/utils": "^0.44.0",
    "@sentry/node": "^8.47.0",
    "@sentry/electron": "^5.6.0",
    "@sentry/types": "^8.47.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
