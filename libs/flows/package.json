{
  "name": "@protolabsai/flows",
  "version": "0.37.1",
  "type": "module",
  "description": "LangGraph state graph examples and patterns for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:basic": "tsx examples/basic-graph.ts",
    "example:hitl": "tsx examples/hitl-graph.ts",
    "example:subgraph": "tsx examples/subgraph-pattern.ts",
    "build:check": "tsc --noEmit"
  },
  "keywords": [
    "automaker",
    "langgraph",
    "state-graphs",
    "flows"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@protolabsai/model-resolver": "^0.37.1",
    "@protolabsai/observability": "^0.37.1",
    "@protolabsai/prompts": "^0.37.1",
    "@protolabsai/types": "^0.37.1",
    "@protolabsai/utils": "^0.37.1",
    "@langchain/anthropic": "^0.3.10",
    "@langchain/core": "^0.3.33",
    "@langchain/langgraph": "^0.2.26"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
