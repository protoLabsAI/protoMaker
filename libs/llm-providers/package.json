{
  "name": "@automaker/llm-providers",
  "version": "1.0.0",
  "type": "module",
  "description": "Multi-provider LLM abstraction layer for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build:check": "tsc --noEmit"
  },
  "keywords": [
    "automaker",
    "llm",
    "providers",
    "anthropic",
    "openai",
    "google",
    "groq",
    "ollama",
    "bedrock"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@automaker/types": "1.0.0",
    "@automaker/utils": "1.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@google/generative-ai": "^0.21.0",
    "@langchain/anthropic": "^0.3.14",
    "@langchain/core": "^0.3.33",
    "groq-sdk": "^0.5.0",
    "ollama": "^0.5.0",
    "openai": "^4.77.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
