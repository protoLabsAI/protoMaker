  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.10",
    "@protolabs-ai/types": "^0.20.0",
    "langfuse": "^3.32.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.33",
    "@types/node": "22.19.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
