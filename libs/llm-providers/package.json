{
  "name": "@protolabs-ai/llm-providers",
  "version": "0.15.4",
  "type": "module",
  "description": "LangChain adapter for the protoLabs provider system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
