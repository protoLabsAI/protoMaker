---
interface Props {
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  footnote?: string;
}

const { heading, description, ctaLabel, ctaHref, footnote } = Astro.props;
---

<section id="get-started" class="border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 text-center fade-section">
    <h2 class="text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
    <p class="mt-4 text-zinc-400 text-sm leading-relaxed max-w-md mx-auto">{description}</p>
    <a
      href={ctaHref}
      class="inline-flex items-center gap-2 mt-8 px-8 py-3.5 bg-accent hover:bg-accent-dim text-white text-sm font-medium rounded-lg transition-colors"
    >
      {ctaLabel}
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
      </svg>
    </a>
    {footnote && <p class="mt-4 text-xs text-zinc-600">{footnote}</p>}
  </div>
</section>
