---
import { getEntry } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';
import FadeIn from '../FadeIn.astro';

const faq = await getEntry('sections', 'faq');
const { label, heading, items } = faq.data;
---

<section id="faq" class="max-w-5xl mx-auto px-6 py-20 md:py-28">
  <FadeIn>
    <SectionLabel label={label} />
    <h2 class="mt-4 text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
  </FadeIn>
  <div class="mt-12 max-w-2xl space-y-8">
    {
      items.map((item) => (
        <FadeIn>
          <div>
            <h3 class="text-white font-medium">{item.question}</h3>
            <p class="mt-2 text-zinc-400 text-sm leading-relaxed">{item.answer}</p>
          </div>
        </FadeIn>
      ))
    }
  </div>
</section>
