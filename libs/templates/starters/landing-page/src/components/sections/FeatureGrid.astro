---
import { getEntry } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';
import FadeIn from '../FadeIn.astro';

const features = await getEntry('sections', 'features');
const { label, heading, items } = features.data;
---

<section id="features" class="border-y border-white/5 bg-surface-1/30">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <FadeIn>
      <SectionLabel label={label} />
      <h2 class="mt-4 text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
    </FadeIn>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        items.map((feature) => (
          <FadeIn>
            <div class="p-6 rounded-xl border border-white/5 bg-surface-0/50 h-full">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-500/15 text-green-400 text-[11px] flex-shrink-0">
                  &#10003;
                </span>
                <h3 class="text-white font-medium">{feature.title}</h3>
              </div>
              <p class="text-zinc-400 text-sm leading-relaxed">{feature.description}</p>
            </div>
          </FadeIn>
        ))
      }
    </div>
  </div>
</section>
