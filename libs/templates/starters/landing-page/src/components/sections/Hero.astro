---
import { getEntry } from 'astro:content';

const config = await getEntry('siteConfig', 'main');
const { brand } = config.data;
---

<div class="max-w-5xl mx-auto px-6 pt-28 pb-16 md:pt-44 md:pb-24">
  <div class="max-w-2xl">
    <h1
      class="text-3xl sm:text-4xl md:text-5xl font-bold leading-[1.1] tracking-tight animate-fade-up"
    >
      {brand.tagline}
    </h1>
    <p
      class="mt-6 text-lg md:text-xl text-zinc-400 leading-relaxed animate-fade-up animate-delay-1"
    >
      {brand.description}
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3 animate-fade-up animate-delay-2">
      <a
        href="#features"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-accent-dim text-white text-sm font-medium rounded-lg transition-colors"
      >
        See how it works
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 px-5 py-2.5 border border-white/10 hover:border-white/20 text-zinc-300 hover:text-white text-sm font-medium rounded-lg transition-colors"
      >
        View pricing
      </a>
    </div>
  </div>
</div>
