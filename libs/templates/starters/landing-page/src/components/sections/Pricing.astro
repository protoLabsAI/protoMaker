---
import { getEntry } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';
import FadeIn from '../FadeIn.astro';

const pricing = await getEntry('sections', 'pricing');
const { label, heading, tiers } = pricing.data;
---

<section id="pricing" class="max-w-5xl mx-auto px-6 py-20 md:py-28">
  <FadeIn class="text-center">
    <SectionLabel label={label} />
    <h2 class="mt-4 text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
  </FadeIn>
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    {
      tiers.map((tier) => (
        <FadeIn>
          <div
            class:list={[
              'rounded-xl border p-6 h-full flex flex-col',
              tier.highlighted
                ? 'border-accent/30 bg-accent/5 glow'
                : 'border-white/5 bg-surface-1/50',
            ]}
          >
            <div>
              <h3 class="text-white font-medium text-lg">{tier.name}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-3xl font-bold font-mono text-white">{tier.price}</span>
                {tier.period && <span class="text-zinc-500 text-sm">{tier.period}</span>}
              </div>
              <p class="mt-3 text-zinc-400 text-sm">{tier.description}</p>
            </div>
            <ul class="mt-6 space-y-3 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-zinc-400">
                  <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-green-500/15 text-green-400 text-[10px] flex-shrink-0 mt-0.5">
                    &#10003;
                  </span>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href={tier.cta.href}
              class:list={[
                'mt-8 inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg transition-colors w-full',
                tier.highlighted
                  ? 'bg-accent hover:bg-accent-dim text-white'
                  : 'border border-white/10 hover:border-white/20 text-zinc-300 hover:text-white',
              ]}
            >
              {tier.cta.label}
            </a>
          </div>
        </FadeIn>
      ))
    }
  </div>
</section>
