---
import { getEntry } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';
import FadeIn from '../FadeIn.astro';

const steps = await getEntry('sections', 'steps');
const { label, heading, items } = steps.data;
---

<section class="max-w-5xl mx-auto px-6 py-20 md:py-28">
  <FadeIn>
    <SectionLabel label={label} />
    <h2 class="mt-4 text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
  </FadeIn>
  <div class="mt-12 space-y-10">
    {
      items.map((step, i) => (
        <FadeIn class="flex items-start gap-5">
          <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-accent/12 text-accent text-sm font-semibold font-mono flex-shrink-0 mt-0.5">
            {i + 1}
          </div>
          <div>
            <h3 class="text-white font-medium text-lg">{step.title}</h3>
            <p class="mt-2 text-zinc-400 text-sm leading-relaxed">{step.description}</p>
            {step.link && (
              <a
                href={step.link.href}
                class="inline-flex items-center gap-1.5 mt-3 text-accent hover:text-white text-sm transition-colors"
              >
                {step.link.label}
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </a>
            )}
          </div>
        </FadeIn>
      ))
    }
  </div>
</section>
