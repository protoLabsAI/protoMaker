---
import { getEntry } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';
import FadeIn from '../FadeIn.astro';

const testimonials = await getEntry('sections', 'testimonials');
const { label, heading, items } = testimonials.data;
---

<section class="border-y border-white/5 bg-surface-1/30">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <FadeIn class="text-center">
      <SectionLabel label={label} />
      <h2 class="mt-4 text-2xl md:text-3xl font-semibold text-white">{heading}</h2>
    </FadeIn>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        items.map((testimonial) => (
          <FadeIn>
            <div class="p-6 rounded-xl border border-white/5 bg-surface-0/50 h-full flex flex-col">
              <blockquote class="text-zinc-400 text-sm leading-relaxed flex-1">
                &ldquo;{testimonial.quote}&rdquo;
              </blockquote>
              <div class="mt-6 pt-4 border-t border-white/5">
                <div class="text-white text-sm font-medium">{testimonial.name}</div>
                <div class="text-zinc-500 text-xs mt-0.5">
                  {testimonial.role}
                  {testimonial.company && <span> at {testimonial.company}</span>}
                </div>
              </div>
            </div>
          </FadeIn>
        ))
      }
    </div>
  </div>
</section>
