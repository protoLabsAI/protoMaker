---
/**
 * About section — bio text, skills grid, and career timeline.
 *
 * Skills and timeline have sensible defaults so the section renders out of
 * the box. Override them via props to match your actual background.
 *
 * Usage:
 *   <About bio={config.bio} />
 *   <About bio={config.bio} skills={mySkills} timeline={myTimeline} />
 */

export interface SkillGroup {
  category: string;
  items: string[];
}

export interface TimelineEntry {
  year: string;
  title: string;
  description: string;
}

interface Props {
  bio: string;
  skills?: SkillGroup[];
  timeline?: TimelineEntry[];
}

const DEFAULT_SKILLS: SkillGroup[] = [
  {
    category: "Languages",
    items: ["TypeScript", "JavaScript", "Python", "SQL"],
  },
  { category: "Frontend", items: ["React", "Astro", "Tailwind CSS", "Figma"] },
  { category: "Backend", items: ["Node.js", "Express", "PostgreSQL", "Redis"] },
  {
    category: "AI / ML",
    items: ["Claude API", "LangChain", "LangGraph", "Langfuse"],
  },
];

const DEFAULT_TIMELINE: TimelineEntry[] = [
  {
    year: "2024",
    title: "Open-source builder",
    description:
      "Shipped several developer tools and shared learnings publicly.",
  },
  {
    year: "2023",
    title: "AI-first development",
    description: "Shifted focus to building with LLMs and agent frameworks.",
  },
  {
    year: "2022",
    title: "Full-stack engineering",
    description: "Led frontend and backend work across multiple product teams.",
  },
  {
    year: "2020",
    title: "Started writing code",
    description:
      "Fell in love with TypeScript, React, and building for the web.",
  },
];

const {
  bio,
  skills = DEFAULT_SKILLS,
  timeline = DEFAULT_TIMELINE,
} = Astro.props;
---

<section class="mx-auto max-w-3xl px-6 py-16">
  <!-- ── Bio ────────────────────────────────────────────────── -->
  <div class="mb-12">
    <h2 class="mb-4 text-2xl font-bold text-white">About me</h2>
    <p class="text-lg leading-relaxed" style="color: #a1a1aa;">{bio}</p>
  </div>

  <!-- ── Skills grid ────────────────────────────────────────── -->
  {
    skills.length > 0 && (
      <div class="mb-14">
        <h3 class="mb-6 text-xl font-bold text-white">Skills &amp; tools</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          {skills.map(({ category, items }) => (
            <div
              class="rounded-xl border p-5"
              style="background: var(--color-surface-2); border-color: var(--border-subtle);"
            >
              <h4
                class="mb-3 text-sm font-semibold uppercase tracking-wide"
                style="color: var(--color-accent);"
              >
                {category}
              </h4>
              <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
                {items.map((item) => (
                  <li
                    class="rounded px-2.5 py-1 text-sm"
                    style="background: var(--color-surface-3); color: #d4d4d8;"
                  >
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    )
  }

  <!-- ── Timeline ────────────────────────────────────────────── -->
  {
    timeline.length > 0 && (
      <div>
        <h3 class="mb-8 text-xl font-bold text-white">Timeline</h3>
        <ol
          class="relative m-0 list-none border-l p-0"
          style="border-color: var(--border-subtle);"
        >
          {timeline.map(({ year, title, description }) => (
            <li class="mb-8 ml-6">
              <span
                class="absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full"
                style="background: var(--color-accent-dim); outline: 4px solid var(--color-surface-0);"
                aria-hidden="true"
              >
                <svg
                  class="h-2.5 w-2.5"
                  viewBox="0 0 10 10"
                  fill="white"
                  aria-hidden="true"
                >
                  <circle cx="5" cy="5" r="5" />
                </svg>
              </span>
              <p
                class="mb-1 text-xs font-semibold uppercase tracking-widest"
                style="color: var(--color-accent);"
              >
                {year}
              </p>
              <h4 class="text-base font-semibold text-white">{title}</h4>
              <p class="mt-1 text-sm leading-relaxed" style="color: #a1a1aa;">
                {description}
              </p>
            </li>
          ))}
        </ol>
      </div>
    )
  }
</section>
