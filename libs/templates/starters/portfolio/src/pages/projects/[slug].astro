---
/**
 * Dynamic project detail page — one page per project slug.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={project.data.image}
>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <!-- Back link -->
    <a
      href="/projects"
      class="mb-8 inline-flex items-center gap-1.5 text-sm no-underline transition-colors"
      style="color: var(--color-muted);"
    >
      ← All projects
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-3">
        <time
          datetime={project.data.pubDate.toISOString()}
          class="text-sm"
          style="color: var(--color-muted);"
        >
          {formattedDate}
        </time>
        {
          project.data.tags.map((tag) => (
            <span
              class="rounded px-2 py-0.5 text-xs"
              style="background: var(--color-surface-3); color: #a1a1aa;"
            >
              {tag}
            </span>
          ))
        }
      </div>

      <h1 class="mb-4 text-3xl font-extrabold text-white sm:text-4xl">
        {project.data.title}
      </h1>

      <p class="text-base leading-relaxed" style="color: #a1a1aa;">
        {project.data.description}
      </p>

      <!-- Tech stack -->
      <ul class="mt-4 flex flex-wrap gap-2 list-none p-0 m-0">
        {
          project.data.techStack.map((tech) => (
            <li
              class="rounded-md px-3 py-1 text-xs font-medium"
              style="background: var(--color-surface-3); color: #a1a1aa;"
            >
              {tech}
            </li>
          ))
        }
      </ul>

      <!-- External links -->
      {
        (project.data.liveUrl || project.data.repoUrl) && (
          <div class="mt-6 flex gap-4">
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener"
                class="rounded-lg px-4 py-2 text-sm font-semibold text-white no-underline transition-opacity hover:opacity-90"
                style="background: var(--color-accent);"
              >
                Live demo →
              </a>
            )}
            {project.data.repoUrl && (
              <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener"
                class="rounded-lg border px-4 py-2 text-sm font-semibold text-white no-underline transition-colors hover:border-white/30"
                style="border-color: var(--border-subtle);"
              >
                View source
              </a>
            )}
          </div>
        )
      }
    </header>

    <!-- Cover image -->
    {
      project.data.image && (
        <div class="mb-10 overflow-hidden rounded-xl border" style="border-color: var(--border-subtle);">
          <img
            src={project.data.image}
            alt={project.data.imageAlt ?? project.data.title}
            class="w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <!-- Body -->
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
