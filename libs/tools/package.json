{
  "name": "@automaker/tools",
  "version": "1.0.0",
  "type": "module",
  "description": "Unified tool implementations for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "watch": "tsup --watch"
  },
  "keywords": [
    "automaker",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@automaker/types": "file:../types",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.19.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "express": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
