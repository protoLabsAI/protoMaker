{
  "name": "@protolabsai/tools",
  "version": "0.48.0",
  "type": "module",
  "description": "Unified tool definition and registry system for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "automaker",
    "tools",
    "registry"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@protolabsai/types": "^0.48.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.1"
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.33",
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "22.19.3",
    "express": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
