{
  "name": "@protolabsai/types",
  "version": "0.37.1",
  "type": "module",
  "description": "Shared type definitions for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
