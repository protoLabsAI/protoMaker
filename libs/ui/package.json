{
  "name": "@protolabsai/ui",
  "version": "0.38.0",
  "type": "module",
  "description": "Shared UI components for AutoMaker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./atoms": {
      "import": "./dist/atoms/index.js",
      "types": "./dist/atoms/index.d.ts",
      "default": "./dist/atoms/index.js"
    },
    "./molecules": {
      "import": "./dist/molecules/index.js",
      "types": "./dist/molecules/index.d.ts",
      "default": "./dist/molecules/index.js"
    },
    "./organisms": {
      "import": "./dist/organisms/index.js",
      "types": "./dist/organisms/index.d.ts",
      "default": "./dist/organisms/index.js"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts",
      "default": "./dist/ai/index.js"
    },
    "./themes.css": "./src/themes/themes.css"
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "build:check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static"
  },
  "keywords": [
    "automaker",
    "ui",
    "components",
    "react",
    "tailwind",
    "design-system",
    "radix-ui",
    "atomic-design"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/protoLabsAI/automaker.git",
    "directory": "libs/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "AutoMaker Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "2.0.2",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "0.562.0",
    "prismjs": "^1.30.0",
    "react-markdown": "10.1.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.4.0"
  },
  "peerDependencies": {
    "@rjsf/core": ">=6",
    "@rjsf/shadcn": ">=6",
    "@rjsf/utils": ">=6",
    "@rjsf/validator-ajv8": ">=6",
    "ai": ">=4",
    "react": ">=19",
    "tailwindcss": ">=4"
  },
  "peerDependenciesMeta": {
    "@rjsf/core": {
      "optional": true
    },
    "@rjsf/shadcn": {
      "optional": true
    },
    "@rjsf/utils": {
      "optional": true
    },
    "@rjsf/validator-ajv8": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@types/node": "22.19.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.10",
    "storybook": "^10.2.8",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
