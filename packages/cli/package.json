{
  "name": "@protolabsai/cli",
  "version": "0.1.0",
  "description": "protomaker CLI — command-line interface for protoLabs.studio",
  "type": "module",
  "bin": {
    "protomaker": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "protomaker",
    "protolabs",
    "cli"
  ],
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}
