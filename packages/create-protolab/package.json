{
  "name": "@automaker/create-protolab",
  "version": "1.0.0",
  "description": "CLI tool for creating and configuring Protolab projects",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "create-protolab": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
