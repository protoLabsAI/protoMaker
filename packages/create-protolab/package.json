{
  "name": "create-protolab",
  "version": "0.6.0",
  "description": "Scan any repo, compare against the ProtoLabs gold standard, and scaffold the full automation stack",
  "type": "module",
  "bin": {
    "create-protolab": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json && npm run postbuild",
    "postbuild": "cp -r templates dist/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "protolab",
    "scaffold",
    "cli",
    "automation",
    "ci-cd",
    "create"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  }
}
