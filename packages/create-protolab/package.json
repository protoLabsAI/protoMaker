{
  "name": "create-protolab",
  "version": "0.1.0",
  "description": "CLI tool to scaffold new Protolab projects",
  "type": "module",
  "bin": {
    "create-protolab": "./dist/cli.js"
  },
  "main": "./dist-cjs/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist-cjs/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs",
    "templates"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run postbuild",
    "build:esm": "tsc --project tsconfig.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && npm run rename:cjs",
    "rename:cjs": "find dist-cjs -name '*.js' -type f -exec sh -c 'mv \"$1\" \"${1%.js}.cjs\"' _ {} \\;",
    "postbuild": "mkdir -p dist/templates && cp -r templates/* dist/templates/ 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "protolab",
    "scaffold",
    "cli",
    "create"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
