    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "protolab",
    "cli",
    "discord",
    "automation"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
