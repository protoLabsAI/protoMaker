{
  "name": "@protolabs-ai/mcp-server",
  "version": "0.31.0",
  "description": "MCP server for interacting with protoLabs Studio board and features",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "automaker-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "automaker",
    "ai-agents",
    "kanban"
  ],
  "dependencies": {
    "@protolabs-ai/tools": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
