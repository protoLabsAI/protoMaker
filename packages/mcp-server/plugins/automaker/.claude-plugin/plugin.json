{
  "name": "automaker",
  "description": "Automaker - AI Development Studio. Manage Kanban boards, AI agents, and feature orchestration.",
  "version": "1.0.6",
  "author": {
    "name": "Proto Labs AI"
  },
  "repository": "https://github.com/proto-labs-ai/automaker",
  "mcpServers": {
    "automaker": {
      "command": "node",
      "args": ["${AUTOMAKER_ROOT}/packages/mcp-server/dist/index.js"],
      "env": {
        "AUTOMAKER_API_URL": "http://localhost:3008",
        "AUTOMAKER_API_KEY": "${AUTOMAKER_API_KEY}",
        "ENABLE_TOOL_SEARCH": "auto:10"
      }
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "mcp-discord"],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    }
  }
}
